---
/**
 * @archivo    Hero.astro
 * @modulo     Sección Hero
 * @descripcion Pantalla completa de bienvenida: video de fondo a opacity 0.22,
 *              meta superior (coordenadas + reel), eyebrow con guión,
 *              H1 cinematográfico en tres líneas (cada una con stagger letter-by-letter),
 *              CTA con flecha y bio breve.
 * @actualizado 2026-05-13
 */
import StaggeredHeadline from "./StaggeredHeadline.astro";
import { CONTACT } from "../data/site";
---

<section
  id="top"
  class="relative min-h-[100svh] flex items-end pb-16 pt-36 px-6 lg:px-12 overflow-hidden"
>
  <!-- Video de fondo: muted, loop, opacity baja para que no compita con el texto -->
  <video
    class="absolute inset-0 w-full h-full object-cover opacity-[0.22]"
    autoplay
    muted
    loop
    playsinline
    poster="https://images.unsplash.com/photo-1485846234645-a62644f84728?w=1600&q=60"
    src="https://assets.mixkit.co/videos/4787/4787-720.mp4"
    aria-hidden="true"></video>

  <!-- Gradiente que oscurece la parte inferior del video para que el texto se lea -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-[#0A0A0A]/50 via-[#0A0A0A]/20 to-[#0A0A0A]"
    aria-hidden="true"
  >
  </div>

  <!-- Meta superior: coordenadas y reel info, en mono uppercase, posicionado abajo del navbar -->
  <div
    class="reveal fade-in absolute top-32 left-6 lg:left-12 right-6 lg:right-12 flex items-start justify-between font-mono text-[11px] tracking-[0.2em] text-slate-400 uppercase"
    style="animation-delay: 1.2s; animation-duration: 0.8s;"
    data-reveal-immediate
  >
    <div class="space-y-1">
      <div set:html={CONTACT.coords} />
      <div class="text-slate-600">{CONTACT.location}</div>
    </div>
    <div class="text-right space-y-1 hidden sm:block">
      <div>Reel 2025 — Vol. IV</div>
      <div class="text-slate-600">07 Películas · 14 Frames</div>
    </div>
  </div>

  <div class="relative w-full">
    <!-- Eyebrow con guión animado -->
    <div
      class="reveal fade-up font-mono text-[11px] tracking-[0.3em] text-slate-400 uppercase mb-8 flex items-center gap-3"
      style="animation-delay: 0.7s; animation-duration: 0.7s;"
      data-reveal-immediate
    >
      <span class="w-8 h-px bg-slate-500"></span>
      Cineasta · Director de Fotografía
    </div>

    <!-- H1 cinemático en 3 líneas, cada una con stagger letra por letra -->
    <h1
      class="font-serif font-medium leading-[0.92] tracking-[-0.02em] text-[clamp(56px,12vw,200px)]"
    >
      <span class="block overflow-hidden">
        <StaggeredHeadline text="Planos que" delay={0.6} />
      </span>
      <span class="block overflow-hidden italic text-slate-300">
        <StaggeredHeadline text="contienen su" delay={0.95} />
      </span>
      <span class="block overflow-hidden">
        <StaggeredHeadline text="aliento." delay={1.25} />
      </span>
    </h1>

    <!-- Bio breve + CTA flecha hacia los trabajos -->
    <div
      class="reveal fade-up mt-12 grid grid-cols-12 gap-6 items-end"
      style="animation-delay: 1.8s; animation-duration: 0.8s;"
      data-reveal-immediate
    >
      <p
        class="col-span-12 lg:col-span-5 text-slate-300 text-[15px] leading-relaxed max-w-md"
      >
        Fran es un cineasta independiente que trabaja en la intersección de la
        narrativa, la marca y el documental — con una mirada atenta a la luz,
        al silencio y al instante justo antes de que algo suceda.
      </p>
      <div
        class="col-span-12 lg:col-span-3 lg:col-start-9 flex lg:justify-end gap-3"
      >
        <a
          href="#work"
          data-cursor="link"
          class="inline-flex items-center gap-3 group"
        >
          <span
            class="w-12 h-12 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-white group-hover:text-black transition-colors"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M12 5v14M5 12l7 7 7-7"></path>
            </svg>
          </span>
          <span class="text-[12px] tracking-[0.22em] uppercase font-medium">
            Trabajos Seleccionados
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
