---
/**
 * @archivo    ContactForm.astro
 * @modulo     Formulario + agenda inline (mismo bloque)
 * @descripcion Sub-sección de Contact.astro. Un solo bloque con header
 *              arriba y dos columnas debajo:
 *              IZQUIERDA: formulario (Web3Forms, AJAX, sin recarga)
 *              DERECHA:   calendario inline embebido (Cal.com, lazy-load)
 *              En mobile las dos columnas se apilan: form arriba, calendario
 *              abajo.
 *
 *              La lógica del submit y la carga lazy del script de Cal.com
 *              están en /src/scripts/main.ts.
 * @actualizado 2026-05-14
 */
import { CONTACT, INTEGRATIONS } from "../data/site";

// ── Normalización del link de Cal.com ────────────────────────────────────
// El campo INTEGRATIONS.calcomLink puede venir como URL completa
// ("https://cal.com/usuario/evento") o como path corto ("usuario/evento").
// La API de Cal.com necesita la forma corta — esta función la extrae.
function normalizeCalLink(input: string): string {
  if (input.startsWith("http")) {
    try {
      return new URL(input).pathname.replace(/^\/+/, "");
    } catch {
      return input;
    }
  }
  return input.replace(/^\/+/, "");
}

const calLink = normalizeCalLink(INTEGRATIONS.calcomLink);
---

<div
  class="mt-20 lg:mt-32 border-t border-white/10 pt-16 lg:pt-24 relative z-10"
>
  <!-- Header del bloque: eyebrow + heading + bajada con link a WhatsApp ── -->
  <!-- Sobre estos están ambas columnas (formulario y calendario). -->
  <div class="grid grid-cols-12 gap-x-6 gap-y-6 mb-14 lg:mb-16 lg:gap-x-12">
    <div class="col-span-12 lg:col-span-5">
      <div
        class="reveal fade-up font-mono text-[11px] tracking-[0.3em] uppercase text-accent mb-6 flex items-center gap-3"
        style="animation-duration: 0.7s;"
      >
        <span class="w-8 h-px bg-accent"></span> Empezá una conversación
      </div>

      <h3
        class="reveal fade-up font-serif text-3xl md:text-4xl lg:text-5xl leading-[1.05] tracking-[-0.02em]"
        style="animation-duration: 0.9s;"
      >
        ¿Tenés un proyecto
        <span class="italic text-accent">en mente?</span>
      </h3>
    </div>

    <div class="col-span-12 lg:col-span-7 lg:flex lg:items-end">
      <p
        class="reveal fade-up text-slate-300 text-[14px] leading-relaxed max-w-md"
        style="animation-duration: 0.8s;"
      >
        Escribime el detalle del proyecto o reservá un horario directo desde
        el calendario. Si preferís hablar al toque,
        <a
          href={CONTACT.whatsapp}
          target="_blank"
          rel="noopener"
          data-cursor="link"
          class="whatsapp-link inline-flex items-center gap-1.5 text-accent hover:text-white font-medium link-underline"
        >
          escribime por WhatsApp
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17L17 7M9 7h8v8"></path>
          </svg>
        </a>.
      </p>
    </div>
  </div>

  <!-- Dos columnas: formulario (izq) + calendario inline (der) ─────────── -->
  <!-- En mobile las dos columnas se apilan. -->
  <div class="grid grid-cols-12 gap-x-6 gap-y-16 lg:gap-x-10">
    <!-- COLUMNA IZQUIERDA: Formulario ───────────────────────────────────-->
    <form
      id="contact-form"
      class="col-span-12 lg:col-span-6 reveal fade-up flex flex-col gap-8"
      style="animation-duration: 0.8s; animation-delay: 0.1s;"
      novalidate
    >
      <!-- Campos ocultos para Web3Forms -->
      <input
        type="hidden"
        name="access_key"
        value={INTEGRATIONS.web3formsKey}
      />
      <input
        type="hidden"
        name="subject"
        value="Nueva consulta — Portfolio Fran Framer"
      />
      <input type="hidden" name="from_name" value="Portfolio Fran Framer" />
      <!-- Honeypot anti-spam -->
      <input
        type="checkbox"
        name="botcheck"
        class="hidden"
        style="display:none"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />

      <!-- Nombre -->
      <label class="block">
        <span class="contact-label">Nombre</span>
        <input
          name="name"
          type="text"
          required
          autocomplete="name"
          class="contact-input"
          placeholder="Tu nombre"
        />
      </label>

      <!-- Email -->
      <label class="block">
        <span class="contact-label">Email</span>
        <input
          name="email"
          type="email"
          required
          autocomplete="email"
          class="contact-input"
          placeholder="tu@email.com"
        />
      </label>

      <!-- Teléfono (opcional) -->
      <label class="block">
        <span class="contact-label">Teléfono — opcional</span>
        <input
          name="phone"
          type="tel"
          autocomplete="tel"
          class="contact-input"
          placeholder="Por si preferís que te llamen / escriban"
        />
      </label>

      <!-- Tipo de proyecto -->
      <label class="block">
        <span class="contact-label">Tipo de proyecto</span>
        <select name="project_type" class="contact-input" required>
          <option value="" disabled selected>Elegí una categoría</option>
          <option value="Cortometraje">Cortometraje</option>
          <option value="Videoclip">Videoclip</option>
          <option value="Video para YouTube">Video para YouTube</option>
          <option value="Pieza de marca">Pieza de marca</option>
          <option value="Podcast">Podcast</option>
          <option value="Cobertura de evento deportivo">
            Cobertura de evento deportivo
          </option>
          <option value="Otro">Otro</option>
        </select>
      </label>

      <!-- Mensaje -->
      <label class="block">
        <span class="contact-label">Contame tu proyecto</span>
        <textarea
          name="message"
          rows="3"
          required
          class="contact-input resize-none"
          placeholder="Idea, fecha tentativa, referencias..."></textarea>
      </label>

      <!-- Submit + estado -->
      <div class="flex items-center justify-between gap-4 flex-wrap mt-auto">
        <p
          id="form-status"
          class="font-mono text-[10px] tracking-[0.22em] uppercase text-slate-500 min-h-[14px]"
          aria-live="polite"
        >
        </p>
        <button
          type="submit"
          data-cursor="link"
          class="submit-button inline-flex items-center gap-2.5 bg-accent text-black px-5 py-2.5"
        >
          <span
            class="font-mono text-[11px] tracking-[0.22em] uppercase font-medium"
          >
            Enviar
          </span>
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M13 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </form>

    <!-- COLUMNA DERECHA: Calendario inline (Cal.com) ────────────────────-->
    <!-- El script de Cal.com se carga lazy en main.ts cuando el div entra
         en viewport (rootMargin 200px). El tema dark + el verde de marca
         se aplican via Cal("ui", ...) después de que el embed monta. -->
    <div
      class="col-span-12 lg:col-span-6 reveal fade-up"
      style="animation-duration: 0.8s; animation-delay: 0.2s;"
    >
      <div
        id="cal-inline"
        class="w-full border border-white/10 bg-[#0a0a0a] overflow-hidden"
        data-cal-link={calLink}
        style="min-width:320px;height:640px;"
      >
      </div>
    </div>
  </div>
</div>

<!-- Estilos locales del formulario ──────────────────────────────────────-->
<style>
  /* Label mono uppercase encima de cada input */
  .contact-label {
    display: block;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 0.65rem;
  }

  /* Input editorial: sin caja, sólo línea inferior que se vuelve verde al focus */
  .contact-input {
    width: 100%;
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    padding: 0.5rem 0;
    color: #fff;
    font-size: 15px;
    font-family: "Inter", system-ui, sans-serif;
    border-radius: 0;
    appearance: none;
    -webkit-appearance: none;
    transition: border-color 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .contact-input:focus {
    outline: none;
    border-bottom-color: #86c91a;
  }

  .contact-input::placeholder {
    color: #334155;
  }

  .contact-input option {
    background: #0a0a0a;
    color: #fff;
  }

  /* Triangulito custom en verde para el select */
  select.contact-input {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2386c91a' stroke-width='1.5'><path d='M6 9l6 6 6-6'/></svg>");
    background-repeat: no-repeat;
    background-position: right 0.25rem center;
    background-size: 16px;
    padding-right: 2rem;
  }

  /* Hover del botón submit y del link de WhatsApp:
     transición lenta del verde lima al verde oscuro de la paleta. */
  .submit-button {
    transition:
      background-color 0.7s cubic-bezier(0.2, 0.7, 0.2, 1),
      color 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .submit-button:hover {
    background-color: #007a08;
    color: #fff;
  }

  .whatsapp-link {
    transition: color 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
</style>
