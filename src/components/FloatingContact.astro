---
/**
 * @archivo    FloatingContact.astro
 * @modulo     Botón flotante de contacto
 * @descripcion Botón circular blanco abajo a la derecha con anillo pulsante.
 *              Al hacer click despliega un panel glass con 3 opciones:
 *              Email, WhatsApp y reservar (scroll a #contact).
 * @actualizado 2026-05-13
 */
import { CONTACT } from "../data/site";
---

<div
  id="floating-contact"
  class="fixed bottom-6 right-6 z-[60] flex flex-col items-end gap-3"
>
  <!-- Panel desplegable (oculto por defecto, lo muestra main.ts al hacer click) -->
  <div
    id="floating-panel"
    class="glass rounded-2xl p-3 flex-col gap-1 min-w-[220px] hidden"
    style="animation: anim-fadeUp 0.4s cubic-bezier(.2,.7,.2,1) both;"
  >
    <a
      href={`mailto:${CONTACT.email}`}
      data-cursor="link"
      class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/5 transition-colors"
    >
      <span
        class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M3 7l9 6 9-6M5 5h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z"></path>
        </svg>
      </span>
      <div>
        <div
          class="text-[11px] font-mono tracking-[0.2em] uppercase text-slate-400"
        >
          Email
        </div>
        <div class="text-[13px] text-white">{CONTACT.email}</div>
      </div>
    </a>
    <a
      href={CONTACT.whatsapp}
      target="_blank"
      rel="noopener"
      data-cursor="link"
      class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/5 transition-colors"
    >
      <span
        class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M5 4h4l2 5-3 2a11 11 0 005 5l2-3 5 2v4a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z"></path>
        </svg>
      </span>
      <div>
        <div
          class="text-[11px] font-mono tracking-[0.2em] uppercase text-slate-400"
        >
          WhatsApp
        </div>
        <div class="text-[13px] text-white">{CONTACT.phone}</div>
      </div>
    </a>
    <a
      href="#contact"
      data-cursor="link"
      data-close-panel
      class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/5 transition-colors"
    >
      <span
        class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M12 2v4M12 18v4M2 12h4M18 12h4M5 5l3 3M16 16l3 3M5 19l3-3M16 8l3-3"
          ></path>
        </svg>
      </span>
      <div>
        <div
          class="text-[11px] font-mono tracking-[0.2em] uppercase text-slate-400"
        >
          Reservar
        </div>
        <div class="text-[13px] text-white">Llamada de 30 min</div>
      </div>
    </a>
  </div>

  <!-- Botón circular con anillo pulsante (animate-ping) -->
  <button
    id="floating-button"
    data-cursor="link"
    aria-label="Abrir menú de contacto"
    aria-expanded="false"
    class="group relative w-14 h-14 rounded-full bg-white text-black flex items-center justify-center shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)] hover:scale-105 transition-transform"
  >
    <span
      class="absolute -inset-1 rounded-full border border-white/30 animate-ping"
    ></span>
    <svg
      id="floating-icon-chat"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
    >
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"></path>
    </svg>
    <svg
      id="floating-icon-close"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      class="hidden"
    >
      <path d="M6 6l12 12M18 6L6 18"></path>
    </svg>
  </button>
</div>
