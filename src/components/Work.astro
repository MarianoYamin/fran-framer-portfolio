---
/**
 * @archivo    Work.astro
 * @modulo     Sección Work / Los proyectos (home)
 * @descripcion Grid destacado de la home. Lee los proyectos de la Content
 *              Collection (src/content/projects/*.json) y muestra SÓLO los
 *              marcados con featured: true. El botón "Ver trabajos" lleva a
 *              /trabajos donde están TODOS agrupados por categoría.
 * @actualizado 2026-05-14
 */
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

// Trae todos los proyectos y los ordena por `order` (menor primero),
// desempatando por título alfabético.
const all = (await getCollection("projects")).sort((a, b) => {
  const byOrder = (a.data.order ?? 0) - (b.data.order ?? 0);
  return byOrder !== 0 ? byOrder : a.data.title.localeCompare(b.data.title);
});

const totalAll = all.length;

// Solo los destacados van en la home. Si ninguno está marcado featured,
// caemos a mostrar todos (para que la home nunca quede vacía).
const featured = all.filter((p) => p.data.featured);
const visible = featured.length > 0 ? featured : all;
const total = visible.length;
---

<section id="work" class="px-6 lg:px-12 py-28 lg:py-40 relative">
  <!-- Header: eyebrow + H2 grande + link a /trabajos -->
  <div class="flex items-end justify-between mb-14 lg:mb-20">
    <div>
      <div
        class="reveal fade-up font-mono text-[11px] tracking-[0.3em] uppercase text-accent mb-4 flex items-center gap-3"
        style="animation-duration: 0.7s;"
      >
        <span class="w-8 h-px bg-accent"></span>
        Trabajos Seleccionados
      </div>
      <h2
        class="reveal fade-up font-serif text-5xl md:text-7xl lg:text-8xl tracking-[-0.02em] leading-[0.95]"
        style="animation-duration: 0.9s;"
      >
        Los <span class="italic text-accent">proyectos.</span>
      </h2>
    </div>
    <a
      href="/trabajos"
      data-cursor="link"
      class="reveal fade-in hidden md:inline-flex items-center gap-2 link-underline text-[12px] tracking-[0.22em] uppercase text-slate-300"
      style="animation-delay: 0.4s; animation-duration: 0.7s;"
    >
      Ver trabajos ({totalAll})
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M5 12h14M13 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>

  <!-- Misma grilla 12-col que /trabajos -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-3 md:gap-4 auto-rows-auto">
    {
      visible.map((entry, i) => (
        <ProjectCard p={entry.data} index={i} total={total} />
      ))
    }
  </div>

  <!-- CTA "Ver trabajos" también en mobile (el de arriba está hidden md:) -->
  <a
    href="/trabajos"
    data-cursor="link"
    class="reveal fade-up md:hidden mt-12 inline-flex items-center gap-2 link-underline text-[12px] tracking-[0.22em] uppercase text-slate-300"
    style="animation-duration: 0.7s;"
  >
    Ver trabajos ({totalAll})
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <path d="M5 12h14M13 5l7 7-7 7"></path>
    </svg>
  </a>
</section>
