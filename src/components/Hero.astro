---
/**
 * @archivo    Hero.astro
 * @modulo     Sección Hero
 * @descripcion Pantalla completa de bienvenida: video de fondo a opacity 0.22,
 *              meta superior (coordenadas + reel) en el flujo natural arriba,
 *              eyebrow con guión, H1 cinematográfico en tres líneas (cada una
 *              con stagger letter-by-letter), CTA con flecha y bio breve.
 *
 *              Estructura: section flex flex-col → top meta arriba (flex-shrink),
 *              wrapper flex-1 con contenido alineado abajo (justify-end).
 *              Esto evita que el H1 enorme empuje el top meta o se superponga
 *              en viewports cortos.
 * @actualizado 2026-05-13
 */
import StaggeredHeadline from "./StaggeredHeadline.astro";
import { CONTACT } from "../data/site";
---

<section
  id="top"
  class="relative min-h-[100svh] flex flex-col pt-24 pb-16 px-6 lg:px-12 overflow-hidden"
>
  <!-- Video de fondo: muted, loop, opacity baja para que no compita con el texto -->
  <video
    class="absolute inset-0 w-full h-full object-cover opacity-[0.22]"
    autoplay
    muted
    loop
    playsinline
    poster="https://images.unsplash.com/photo-1485846234645-a62644f84728?w=1600&q=60"
    src="/mirando-mar.mp4"
    aria-hidden="true"></video>

  <!-- Gradiente que oscurece la parte inferior del video para que el texto se lea -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-[#0A0A0A]/50 via-[#0A0A0A]/20 to-[#0A0A0A]"
    aria-hidden="true"
  >
  </div>

  <!-- Meta superior: coordenadas y reel info en el flujo natural arriba. -->
  <!-- Ya no es absolute para que NO se superponga con el contenido en viewports cortos. -->
  <div
    class="reveal fade-in relative z-10 flex items-start justify-between font-mono text-[11px] tracking-[0.2em] text-accent uppercase"
    style="animation-delay: 1.2s; animation-duration: 0.8s;"
    data-reveal-immediate
  >
    <div class="space-y-1">
      <div set:html={CONTACT.coords} />
      <div class="text-slate-600">{CONTACT.location}</div>
    </div>
    <div class="text-right space-y-1 hidden sm:block">
      <div>Reel 2026 — Vol. I</div>
    </div>
  </div>

  <!-- Wrapper que ocupa el resto del espacio y empuja el contenido al fondo -->
  <div class="relative z-10 flex-1 flex flex-col justify-end w-full">
    <!-- Eyebrow con guión animado -->
    <div
      class="reveal fade-up font-mono text-[10px] sm:text-[11px] tracking-[0.18em] sm:tracking-[0.25em] text-accent uppercase mb-8 flex items-center gap-3 leading-[1.6]"
      style="animation-delay: 0.7s; animation-duration: 0.7s;"
      data-reveal-immediate
    >
      <span class="w-8 h-px bg-accent shrink-0"></span>
      Filmmaker · Editor de Videos · Diseñador y Animador Digital
    </div>

    <!-- H1 cinemático en 4 líneas, cada una con stagger letra por letra.
         Frase: "El encuadre exacto donde vive tu historia."
         La línea italic verde ("exacto") es el acento de marca. -->
    <h1
      class="font-serif font-medium leading-[0.92] tracking-[-0.02em] text-[clamp(48px,11vw,180px)]"
    >
      <span class="block overflow-hidden">
        <StaggeredHeadline text="El encuadre" delay={0.5} />
      </span>
      <span class="block overflow-hidden italic text-accent">
        <StaggeredHeadline text="exacto" delay={0.75} />
      </span>
      <span class="block overflow-hidden">
        <StaggeredHeadline text="donde vive" delay={1.0} />
      </span>
      <span class="block overflow-hidden">
        <StaggeredHeadline text="tu historia." delay={1.25} />
      </span>
    </h1>

    <!-- Bio breve + CTA flecha hacia los trabajos -->
    <div
      class="reveal fade-up mt-12 grid grid-cols-12 gap-6 items-end"
      style="animation-delay: 1.8s; animation-duration: 0.8s;"
      data-reveal-immediate
    >
      <p
        class="col-span-12 lg:col-span-6 text-slate-300 text-[15px] leading-relaxed max-w-xl"
      >
        Soy un creador visual enfocado en resolver desafíos con agilidad.
        Desde la dirección de cortometrajes hasta la ideación de reels de
        alto impacto, combino una fuerte narrativa visual con técnicas
        profesionales de iluminación y composición para transmitir
        exactamente lo que tu proyecto necesita.
      </p>
      <div
        class="col-span-12 lg:col-span-3 lg:col-start-9 flex lg:justify-end gap-3"
      >
        <a
          href="#work"
          data-cursor="link"
          class="inline-flex items-center gap-3 group"
        >
          <span
            class="w-12 h-12 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-white group-hover:text-black transition-colors"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M12 5v14M5 12l7 7-7 7"></path>
            </svg>
          </span>
          <span class="text-[12px] tracking-[0.22em] uppercase font-medium">
            Trabajos Seleccionados
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
